# Optional. Defaults to ~/.lark-radar
LARK_RADAR_DATA_DIR=

# Comma-separated names used to detect messages that mention you.
# Example: LARK_RADAR_MY_NAMES=张三,San Zhang,zhangsan
LARK_RADAR_MY_NAMES=

# Use demo data when lark-cli is unavailable. Set to 1 to enable.
LARK_RADAR_DEMO=0

# Optional model name used by Codex CLI based topic/link summarization.
LARK_RADAR_CODEX_MODEL=

# Optional. Tune Codex CLI aggregation.
LARK_RADAR_TOPIC_CHUNK_SIZE=250
LARK_RADAR_CODEX_TIMEOUT_MS=300000
LARK_RADAR_LINK_CODEX_TIMEOUT_MS=180000
LARK_RADAR_AUTO_TOPIC_DAYS=31
