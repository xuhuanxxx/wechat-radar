{
  "name": "lark-radar",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Lark group intelligence dashboard (monorepo root)",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "pnpm --filter @lark-radar/web dev",
    "build": "pnpm --filter @lark-radar/web build",
    "start": "pnpm --filter @lark-radar/web start",
    "lint": "pnpm --filter @lark-radar/web lint",
    "build:data-service": "cd apps/data-service && go build -o ../../dist/lark-radar-server .",
    "build:macos-app": "./scripts/build-macos-app.sh"
  },
  "packageManager": "pnpm@9.0.0"
}
