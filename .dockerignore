# Build context = repo root. Web Dockerfile only needs apps/web + workspace manifests.

.git
.gitignore

# Installed dependencies — pnpm reinstalls inside the image.
node_modules
**/node_modules

# Next.js / build outputs
**/.next
**/out
dist

# Local env / runtime data
.env
.env.local
.env.*.local
data
**/*.db
**/*.db-shm
**/*.db-wal
**/*.sqlite*

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / IDE
.DS_Store
Thumbs.db
.vscode
.idea
*.swp
*.swo

# Sibling apps not needed by the web image
apps/data-service
apps/macos-menu

# Project metadata not needed inside the image
docs
scripts
README.md
DISCLAIMER.md
PRIVACY.md
SECURITY.md
LICENSE
CLAUDE.md
AGENTS.md

# Test coverage
coverage
.nyc_output
